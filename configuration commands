##Create LVM Partition

sudo fdisk /dev/vdb
  n  → new
p  → primary
1
Enter (full disk)
t  → change type
8e → Linux LVM
w

sudo apt install lvm2 -y

sudo pvcreate /dev/vdb1

sudo vgcreate samba_vg /dev/vdb1

# Mirpur
sudo lvcreate -L 20G -n mirpur_lv samba_vg

# Gulshan
sudo lvcreate -L 20G -n gulshan_lv samba_vg

# Uttara
sudo lvcreate -L 20G -n uttara_lv samba_vg

# Common
sudo lvcreate -L 40G -n common_lv samba_vg

# Admin (remaining)
sudo lvcreate -l 100%FREE -n admin_lv samba_vg

##Format Volumes
sudo mkfs.ext4 /dev/samba_vg/mirpur_lv
sudo mkfs.ext4 /dev/samba_vg/gulshan_lv
sudo mkfs.ext4 /dev/samba_vg/uttara_lv
sudo mkfs.ext4 /dev/samba_vg/common_lv
sudo mkfs.ext4 /dev/samba_vg/admin_lv

  
sudo mkdir -p /srv/samba/{mirpur,gulshan,uttara,common,admin}

##Mount Volumes

sudo mount /dev/samba_vg/mirpur_lv /srv/samba/mirpur
sudo mount /dev/samba_vg/gulshan_lv /srv/samba/gulshan
sudo mount /dev/samba_vg/uttara_lv /srv/samba/uttara
sudo mount /dev/samba_vg/common_lv /srv/samba/common
sudo mount /dev/samba_vg/admin_lv /srv/samba/admin

